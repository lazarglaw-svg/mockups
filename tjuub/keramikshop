<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Espresso Tasse Handgefertigt | Alte Schmiede Keramik</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color: #2c2215; background: #fff; }

    /* ─── ANNOUNCEMENT BAR ─── */
    .announcement-bar {
      background: #2c2215; color: #f5ede3;
      text-align: center; padding: 9px 20px;
      font-size: 12px; letter-spacing: 0.08em;
    }
    .announcement-bar span { opacity: 0.5; margin: 0 14px; }

    /* ─── HEADER ─── */
    header {
      background: #faf8f5; border-bottom: 1px solid #e8e0d5;
      padding: 0 40px; position: sticky; top: 0; z-index: 100;
    }
    .nav-inner {
      max-width: 1280px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between; height: 70px;
    }
    .nav-logo img { height: 40px; object-fit: contain; }
    .nav-logo-text { font-size: 22px; font-weight: 700; color: #2c2215; text-decoration: none; }
    .nav-links { display: flex; gap: 24px; align-items: center; }
    .nav-links a { text-decoration: none; color: #2c2215; font-size: 12px; letter-spacing: 0.1em; font-weight: 500; text-transform: uppercase; opacity: 0.75; }
    .nav-links a:hover { opacity: 1; }
    .nav-icons { display: flex; gap: 18px; align-items: center; }
    .nav-icons svg { width: 20px; height: 20px; cursor: pointer; }

    /* ─── PRODUCT HERO ─── */
    .product-hero {
      max-width: 1280px; margin: 0 auto;
      padding: 48px 40px 64px;
      display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start;
    }

    /* GALLERY */
    .gallery { display: flex; flex-direction: column; gap: 10px; }
    .gallery-main { width: 100%; aspect-ratio: 1; overflow: hidden; background: #f0ebe3; }
    .gallery-main img { width: 100%; height: 100%; object-fit: cover; display: block; cursor: zoom-in; }
    .gallery-thumbs { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
    .gallery-thumbs img { width: 100%; aspect-ratio: 1; object-fit: cover; cursor: pointer; border: 2px solid transparent; transition: border-color 0.15s; background: #f0ebe3; }
    .gallery-thumbs img.active, .gallery-thumbs img:hover { border-color: #8b5e3c; }

    /* PRODUCT INFO */
    .product-info { padding-top: 6px; }

    /* BREADCRUMB-STYLE TAG – statt Badge */
    .product-tag {
      font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
      color: #8b5e3c; font-weight: 600; margin-bottom: 10px;
    }

    .product-info h1 {
      font-size: 28px; font-weight: 600; line-height: 1.25;
      letter-spacing: -0.01em; margin-bottom: 8px; color: #1e160e;
    }

    /* STERNE-BEWERTUNG */
    .rating-row {
      display: flex; align-items: center; gap: 8px; margin-bottom: 14px;
    }
    .stars { color: #f5c228; font-size: 16px; letter-spacing: 2px; }
    .rating-score { font-size: 13px; font-weight: 700; color: #1e160e; }
    .rating-link { font-size: 12px; color: #8b5e3c; text-decoration: underline; cursor: pointer; }

    .product-subtitle { font-size: 14px; color: #7a6450; margin-bottom: 18px; line-height: 1.65; }
    .price-row { font-size: 26px; font-weight: 500; color: #1e160e; margin-bottom: 4px; }
    .price-note { font-size: 12px; color: #9a8270; margin-bottom: 20px; }
    .divider { border: none; border-top: 1px solid #e8e0d5; margin: 18px 0; }

    /* USP – schlichte horizontale Zeile mit Häkchen */
    .usp-strip {
      display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 22px;
    }
    .usp-pill {
      display: flex; align-items: center; gap: 6px;
      padding: 6px 12px; border-radius: 20px;
      border: 1px solid #ddd0c0;
      font-size: 11px; font-weight: 600; letter-spacing: 0.06em;
      color: #5a4232; text-transform: uppercase;
      background: #faf8f5;
    }
    .usp-pill svg { width: 13px; height: 13px; color: #8b5e3c; flex-shrink: 0; }

    /* GLASUR – runde Farbkreise */
    .label {
      font-size: 11px; letter-spacing: 0.12em; font-weight: 700;
      text-transform: uppercase; margin-bottom: 12px; color: #2c2215;
    }
    .swatch-options { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 24px; }
    .swatch-btn {
      display: flex; flex-direction: column; align-items: center; gap: 7px;
      cursor: pointer; background: none; border: none; padding: 0;
      width: 64px;
    }
    .swatch-circle {
      width: 32px; height: 32px; border-radius: 50%;
      border: 2px solid transparent;
      outline: 2px solid transparent;
      transition: outline-color 0.15s, border-color 0.15s;
      position: relative; overflow: hidden;
    }
    .swatch-btn.active .swatch-circle,
    .swatch-btn:hover .swatch-circle {
      outline-color: #8b5e3c; outline-offset: 3px;
    }
    .swatch-name { font-size: 9px; letter-spacing: 0.06em; text-transform: uppercase; color: #5a4232; font-weight: 600; }

    /* Glasur-Farben */
    .s-erdig { background: #c4a882; }
    .s-gruen { background: #6b9e6b; }
    .s-gruen-s { background: radial-gradient(circle at 25% 35%, #3a6e3a 3px, transparent 3px),
                              radial-gradient(circle at 65% 70%, #2f5c2f 2px, transparent 2px),
                              radial-gradient(circle at 80% 25%, #3a6e3a 2px, transparent 2px),
                              #6b9e6b; }
    .s-tuerkis { background: #5aa8b0; }
    .s-tuerkis-s { background: radial-gradient(circle at 30% 40%, #2d7a82 3px, transparent 3px),
                                radial-gradient(circle at 70% 65%, #256870 2px, transparent 2px),
                                radial-gradient(circle at 55% 20%, #2d7a82 2px, transparent 2px),
                                #5aa8b0; }

    /* QTY + CART */
    .qty-row { display: flex; align-items: center; border: 1px solid #c8b8a4; width: fit-content; margin-bottom: 16px; }
    .qty-btn { width: 40px; height: 44px; border: none; background: #faf8f5; font-size: 18px; cursor: pointer; display: flex; align-items: center; justify-content: center; color: #2c2215; }
    .qty-num { width: 44px; text-align: center; font-size: 14px; border-left: 1px solid #c8b8a4; border-right: 1px solid #c8b8a4; line-height: 44px; font-weight: 500; }
    .btn-cart { width: 100%; padding: 16px; background: #2c2215; color: #f5ede3; border: none; font-size: 12px; letter-spacing: 0.14em; font-weight: 700; text-transform: uppercase; cursor: pointer; margin-bottom: 10px; }
    .btn-cart:hover { background: #3d3020; }
    .btn-wishlist { width: 100%; padding: 14px; background: #fff; border: 1px solid #c8b8a4; font-size: 12px; letter-spacing: 0.1em; font-weight: 500; text-transform: uppercase; cursor: pointer; color: #5a4232; margin-bottom: 20px; }

    /* TRUST BADGES */
    .trust-badges { display: flex; flex-direction: column; gap: 10px; padding: 16px; background: #faf8f5; border: 1px solid #e8e0d5; border-radius: 6px; }
    .trust-badge { display: flex; align-items: center; gap: 10px; font-size: 12px; color: #5a4232; }
    .trust-badge svg { width: 15px; height: 15px; color: #8b5e3c; flex-shrink: 0; }

    /* ─── SECTIONS ─── */
    .section-title { font-size: 11px; letter-spacing: 0.18em; font-weight: 700; text-transform: uppercase; color: #8b5e3c; margin-bottom: 10px; }
    .section-heading { font-size: 28px; font-weight: 600; margin-bottom: 40px; letter-spacing: -0.01em; color: #1e160e; }

    /* ─── TAGLINE ─── */
    .tagline-section { background: #f0ebe3; padding: 64px 40px; text-align: center; }
    .tagline-section h2 { font-size: 34px; font-weight: 300; line-height: 1.4; max-width: 640px; margin: 0 auto 16px; color: #1e160e; letter-spacing: -0.01em; }
    .tagline-section p { font-size: 14px; color: #7a6450; max-width: 500px; margin: 0 auto; line-height: 1.8; }

    /* ─── FEATURES ─── */
    .features-section { padding: 72px 40px; max-width: 1280px; margin: 0 auto; }
    .features-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
    .feature-card { border: 1px solid #e8e0d5; padding: 30px 22px; text-align: center; background: #faf8f5; }
    .feature-card svg { width: 36px; height: 36px; margin-bottom: 16px; color: #8b5e3c; }
    .feature-card h3 { font-size: 12px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 10px; color: #1e160e; }
    .feature-card p { font-size: 12px; color: #7a6450; line-height: 1.7; }

    /* ─── PROZESS-SWIPER ─── */
    .process-flow-section { background: #2c2215; padding: 72px 0 80px; overflow: hidden; }
    .process-flow-inner { max-width: 1280px; margin: 0 auto; padding: 0 40px; }
    .process-flow-section .section-title { color: #c4906a; }
    .process-flow-section .section-heading { color: #f5ede3; margin-bottom: 40px; }

    .process-swiper-wrap {
      overflow-x: auto;
      overflow-y: visible;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      display: flex;
      gap: 16px;
      padding: 0 40px 20px;
      cursor: grab;
    }
    .process-swiper-wrap::-webkit-scrollbar { display: none; }
    .process-swiper-wrap.grabbing { cursor: grabbing; }

    .process-step-card {
      flex: 0 0 280px;
      scroll-snap-align: start;
      background: #3d3020;
      border-radius: 4px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }
    .process-step-card .step-photo {
      width: 100%; aspect-ratio: 4/3;
      object-fit: cover;
      display: block;
      filter: brightness(0.88);
    }
    .process-step-body { padding: 20px; flex: 1; }
    .step-num-line {
      font-size: 10px; font-weight: 700; letter-spacing: 0.16em;
      color: #8b5e3c; text-transform: uppercase; margin-bottom: 8px;
    }
    .step-title { font-size: 14px; font-weight: 700; color: #f5ede3; margin-bottom: 8px; letter-spacing: 0.02em; }
    .step-desc { font-size: 12px; color: #9a8270; line-height: 1.7; }

    /* Scroll-Indikator Dots */
    .swiper-dots { display: flex; gap: 6px; justify-content: center; margin-top: 20px; }
    .swiper-dot { width: 6px; height: 6px; border-radius: 50%; background: #5a4232; transition: background 0.2s; }
    .swiper-dot.active { background: #c4906a; }

    /* ─── SPECS ─── */
    .specs-section { background: #f0ebe3; padding: 72px 40px; }
    .specs-inner { max-width: 1280px; margin: 0 auto; }
    .specs-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px; margin-top: 0; }
    .spec-card { background: #fff; padding: 30px 20px; text-align: center; border: 1px solid #e8e0d5; }
    .spec-card svg { width: 28px; height: 28px; margin-bottom: 12px; color: #8b5e3c; }
    .spec-value { font-size: 24px; font-weight: 700; margin-bottom: 4px; color: #1e160e; letter-spacing: -0.02em; }
    .spec-label { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #9a8270; font-weight: 500; }

    /* ─── REVIEWS ─── */
    #reviews { padding: 72px 40px; max-width: 900px; margin: 0 auto; }
    #reviews .section-heading { margin-bottom: 8px; }
    .reviews-summary {
      display: flex; align-items: center; gap: 20px;
      padding: 24px; background: #faf8f5; border: 1px solid #e8e0d5;
      margin-bottom: 32px; border-radius: 4px;
    }
    .reviews-big-score { font-size: 52px; font-weight: 700; color: #1e160e; line-height: 1; }
    .reviews-stars-row { color: #f5c228; font-size: 20px; letter-spacing: 3px; margin-bottom: 4px; }
    .reviews-count { font-size: 12px; color: #9a8270; }
    .review-card { padding: 20px 0; border-top: 1px solid #e8e0d5; }
    .review-card:last-child { border-bottom: 1px solid #e8e0d5; }
    .review-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
    .review-author { font-size: 13px; font-weight: 700; color: #1e160e; }
    .review-stars { color: #f5c228; font-size: 13px; }
    .review-date { font-size: 11px; color: #aaa; margin-top: 2px; }
    .review-text { font-size: 13px; color: #6a5444; line-height: 1.7; }

    /* ─── FAQ ─── */
    .faq-section { max-width: 800px; margin: 0 auto; padding: 72px 40px; }
    .faq-item { border-top: 1px solid #e8e0d5; padding: 20px 0; }
    .faq-item:last-child { border-bottom: 1px solid #e8e0d5; }
    .faq-q { display: flex; justify-content: space-between; align-items: center; font-size: 14px; font-weight: 600; cursor: pointer; color: #1e160e; }
    .faq-icon { width: 22px; height: 22px; border: 1px solid #c8b8a4; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0; color: #8b5e3c; }
    .faq-a { font-size: 13px; color: #7a6450; margin-top: 12px; line-height: 1.8; }

    /* ─── NEWSLETTER ─── */
    .newsletter-section { background: #2c2215; padding: 64px 40px; text-align: center; }
    .newsletter-section h2 { font-size: 22px; font-weight: 600; color: #f5ede3; margin-bottom: 8px; }
    .newsletter-section p { font-size: 13px; color: #9a8270; margin-bottom: 28px; line-height: 1.7; }
    .newsletter-form { display: flex; gap: 0; max-width: 420px; margin: 0 auto; }
    .newsletter-form input { flex: 1; padding: 14px 18px; border: 1px solid #5a4232; border-right: none; font-size: 13px; outline: none; background: #3d3020; color: #f5ede3; }
    .newsletter-form input::placeholder { color: #7a6450; }
    .newsletter-form button { padding: 14px 24px; background: #8b5e3c; color: #fff; border: none; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 700; cursor: pointer; }

    /* ─── RELATED ─── */
    .related-section { padding: 72px 40px; max-width: 1280px; margin: 0 auto; }
    .related-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; }
    .related-card { cursor: pointer; }
    .related-card img { width: 100%; aspect-ratio: 1; object-fit: cover; margin-bottom: 14px; background: #f0ebe3; }
    .related-name { font-size: 13px; font-weight: 600; margin-bottom: 4px; color: #1e160e; }
    .related-price { font-size: 13px; color: #8b5e3c; font-weight: 500; }

    /* ─── FOOTER ─── */
    footer { background: #1e160e; color: #9a8270; padding: 20px 40px; text-align: center; font-size: 11px; letter-spacing: 0.08em; }

    /* ─── MOBILE ─── */
    @media (max-width: 768px) {
      header { padding: 0 16px; }
      .nav-links { display: none; }
      .nav-logo img { height: 32px; }
      .announcement-bar { font-size: 10px; padding: 8px 12px; }
      .product-hero { grid-template-columns: 1fr; gap: 24px; padding: 20px 16px 40px; }
      .tagline-section { padding: 40px 20px; }
      .tagline-section h2 { font-size: 24px; }
      .features-section { padding: 40px 16px; }
      .features-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
      .process-flow-section { padding: 40px 0 48px; }
      .process-flow-inner { padding: 0 16px; }
      .process-swiper-wrap { padding: 0 16px 16px; }
      .process-step-card { flex: 0 0 260px; }
      .specs-section { padding: 40px 16px; }
      .specs-grid { grid-template-columns: 1fr 1fr; }
      #reviews { padding: 40px 16px; }
      .faq-section { padding: 40px 16px; }
      .newsletter-section { padding: 40px 16px; }
      .newsletter-form { flex-direction: column; }
      .newsletter-form input, .newsletter-form button { width: 100%; border-right: 1px solid #5a4232; }
      .related-section { padding: 40px 16px; }
      .related-grid { grid-template-columns: 1fr 1fr; gap: 16px; }
      .usp-strip { gap: 6px; }
    }
    @media (max-width: 480px) {
      .features-grid { grid-template-columns: 1fr; }
      .process-flow-grid { grid-template-columns: 1fr; }
      .specs-grid { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
